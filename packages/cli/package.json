{
  "name": "@honua/cli",
  "version": "1.0.0-alpha.1",
  "description": "Cross-platform command-line interface for Honua geospatial services administration",
  "main": "dist/index.js",
  "bin": {
    "honua": "dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "build:binary": "npm run build && pkg package.json --out-path build/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "geospatial",
    "gis",
    "admin",
    "cli",
    "automation",
    "devops",
    "postgis",
    "honua"
  ],
  "author": "Honua Project Contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikemcdougall/honua-admin-tools.git",
    "directory": "packages/cli"
  },
  "homepage": "https://docs.honua.dev/admin-tools/cli",
  "bugs": {
    "url": "https://github.com/mikemcdougall/honua-admin-tools/issues"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@honua/admin-tools": "^1.0.0-alpha.1",
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.0",
    "table": "^6.8.1",
    "yaml": "^2.3.2",
    "form-data": "^4.0.0",
    "fs-extra": "^11.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "pkg": "^5.8.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "node_modules/@honua/admin-tools/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ],
    "outputPath": "build"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ],
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}