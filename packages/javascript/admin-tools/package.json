{
  "name": "@honua/admin-tools",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript admin tooling for Honua geospatial platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js",
      "types": "./dist/vue.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:dev": "rollup -c --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikemcdougall/honua-admin-tools.git",
    "directory": "packages/javascript/admin-tools"
  },
  "keywords": [
    "honua",
    "geospatial",
    "gis",
    "admin",
    "tools",
    "management",
    "bulk-operations",
    "grpc",
    "typescript",
    "javascript"
  ],
  "author": "Honua Project Contributors",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/mikemcdougall/honua-admin-tools/issues"
  },
  "homepage": "https://github.com/mikemcdougall/honua-admin-tools/tree/master/packages/javascript/admin-tools#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "rollup": "^4.9.0",
    "rollup-plugin-dts": "^6.1.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}